# Server
NODE_ENV=development
PORT=3000

# Redis
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
BLACKLIST_TTL_SECONDS=604800

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=identity_service
DB_SCHEMA=public
DB_SYNCHRONIZE=true
DB_SSL=false
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_LOGGING=true

#JWT
JWT_SECRET=secret
JWT_EXPIRES_IN=1h
JWT_EXPIRES_IN_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=604800

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_ONE_TAP_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_CALLBACK_URL=

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_CALLBACK_URL=

# Feature Flags (OAuth)
ENABLE_GOOGLE_OAUTH_REDIRECT=false
ENABLE_MICROSOFT_OAUTH_REDIRECT=false
ENABLE_SLACK_OAUTH_REDIRECT=false

# Feature Flags (Token Exchange)
ENABLE_GOOGLE_TOKEN_EXCHANGE=true
ENABLE_MICROSOFT_TOKEN_EXCHANGE=true
ENABLE_SLACK_TOKEN_EXCHANGE=true